# ---------------------------------------------------------------------------
# Secrets — NEVER commit these. Blocks .env AND .env.example, because the
# example file currently contains a live Together API key. Once you scrub the
# key out of .env.example (replace with a placeholder), you can force-add a
# clean template with:  git add -f .env.example
# ---------------------------------------------------------------------------
.env
.env.*
*.env
secrets.*
*.key
*.pem

# ---------------------------------------------------------------------------
# Generated data
# ---------------------------------------------------------------------------
# Chroma vector store — large, binary, regenerable via `python scripts/01_ingest.py`
data/chroma/

# Evaluation RUN outputs (regenerable via `python scripts/03_run_eval.py`).
# The eval SETS (*_eval_set.jsonl) stay tracked — they are the benchmark and
# matter for reproducibility.
data/eval/*results*
data/eval/*.csv

# Local scratch/output dirs
output/
outputs/
scratch/
tmp/

